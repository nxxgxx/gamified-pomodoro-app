generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  user_id    Int      @id @default(autoincrement())
  username   String
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  onboard_complete Boolean @default(false)
  current_style     String?

  inventories Inventory[]
  timers      Timer[]

  selected_inventory_id Int? @unique
  selected_inventory Inventory? @relation("SelectedInventory", fields: [selected_inventory_id], references: [inventory_id], onDelete: Restrict, onUpdate: Restrict)
}

model Pokemon {
  pokemon_id Int    @id @default(autoincrement())
  pokedex_id Int
  name       String @unique
  nickname   String
  rarity     Rarity
  image_url  String

  next_evolution_id Int?
  next_evolution    Pokemon? @relation("NextEvolution", fields: [next_evolution_id], references: [pokemon_id], onDelete: Restrict, onUpdate: Restrict)
  evolve_level      Int?

  previous_evolutions Pokemon[] @relation("NextEvolution")

  inventories Inventory[]
}

model Inventory {
  inventory_id Int @id @default(autoincrement())

  user_id Int
  user    User @relation(fields: [user_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict)

  pokemon_id Int
  pokemon    Pokemon @relation(fields: [pokemon_id], references: [pokemon_id], onDelete: Restrict, onUpdate: Restrict)

  nickname   String?
  created_at DateTime @default(now())
  experience Int @default(0)

  selected_by_user User? @relation("SelectedInventory")
}

model Timer {
  timer_id   Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [user_id], onDelete: Restrict, onUpdate: Restrict)
  start_time DateTime
  end_time   DateTime
  duration   Int
  completed  Boolean  @default(false)
}

enum Rarity {
  COMMON
  UNCOMMON
  RARE
  LEGENDARY
}
